<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.atm1020.tuilaunch</id>
    <name>TUILaunch</name>
    <vendor>atm1020</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>
    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.atm1020.tuilaunch.services.TuiLauncherSettings"/>
        <applicationConfigurable parentId="tools" instance="com.github.atm1020.tuilaunch.ui.TuiLauncherConfiguration"
                                 id="com.example.tuilauncher.TuiLauncherConfigurable"
                                 displayName="TUI Launcher"/>
        <postStartupActivity implementation="com.github.atm1020.tuilaunch.LoadDynamicActions"/>
        <toolWindow id="TUILaunch"
                    anchor="bottom"
                    canCloseContents="false"
                    factoryClass="com.github.atm1020.tuilaunch.toolwindow.TuiLaunchToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="TUILauncher.FocusTui"
                class="com.github.atm1020.tuilaunch.action.FocusTuiAction"
                text="TUILaunch Focus"
                description="Move keyboard focus to the active TUI session">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="TUILauncher.FocusEditor"
                class="com.github.atm1020.tuilaunch.action.FocusEditorAction"
                text="TUILaunch Focus Editor"
                description="Move keyboard focus back to the editor">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="TUILauncher.ToggleFocus"
                class="com.github.atm1020.tuilaunch.action.ToggleFocusAction"
                text="TUILaunch Toggle Focus"
                description="Toggle focus between the TUI session and the editor">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="TUILauncher.ToggleToolWindow"
                class="com.github.atm1020.tuilaunch.action.ToggleToolWindowAction"
                text="TUILaunch Toggle Tool Window"
                description="Show or hide the TUILaunch tool window">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="TUILauncher.CloseActiveTui"
                class="com.github.atm1020.tuilaunch.action.CloseActiveTuiAction"
                text="TUILaunch Close Active TUI"
                description="Close the currently selected TUI session tab">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="TUILauncher.NextTuiTab"
                class="com.github.atm1020.tuilaunch.action.NextTuiTabAction"
                text="TUILaunch Next TUI Tab"
                description="Move focus to the next open TUI session tab">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="TUILauncher.NextTuiTabWithoutFocus"
                class="com.github.atm1020.tuilaunch.action.NextTuiTabWithoutFocusAction"
                text="TUILaunch Next TUI Tab Without Focus"
                description="Move to the next open TUI session tab without requesting terminal focus">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="TUILauncher.PreviousTuiTab"
                class="com.github.atm1020.tuilaunch.action.PreviousTuiTabAction"
                text="TUILaunch Previous TUI Tab"
                description="Move focus to the previous open TUI session tab">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="TUILauncher.PreviousTuiTabWithoutFocus"
                class="com.github.atm1020.tuilaunch.action.PreviousTuiTabWithoutFocusAction"
                text="TUILaunch Previous TUI Tab Without Focus"
                description="Move to the previous open TUI session tab without requesting terminal focus">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
